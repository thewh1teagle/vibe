{
	"$schema": "./gen/schemas/desktop-schema.json",
	"productName": "vibe",
	"version": "3.0.19",
	"identifier": "github.com.thewh1teagle.vibe",
	"app": {
		"windows": [],
		"withGlobalTauri": true,
		"security": {
			"assetProtocol": {
				"scope": {
					"allow": [
						"**"
					],
					"deny": [],
					"requireLiteralLeadingDot": false
				},
				"enable": true
			},
			"csp": null
		}
	},
	"build": {
		"beforeDevCommand": "pnpm dev",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist",
		"devUrl": "http://localhost:1420"
	},
	"bundle": {
		"active": true,
		"targets": [
			"nsis"
		],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"externalBin": [
			"binaries/sona"
		],
		"resources": {
			"locales": "locales"
		}
	},
	"plugins": {}
}
