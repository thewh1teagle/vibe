{
	"name": "website",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"packageManager": "pnpm@10.4.1",
	"scripts": {
		"dev": "vite",
		"i18n:generate": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --emit-ts-declarations --strategy localStorage preferredLanguage baseLocale",
		"build": "pnpm i18n:generate && tsc && vite build && cp dist/index.html dist/404.html",
		"preview": "vite preview"
	},
	"devDependencies": {
		"@inlang/paraglide-js": "2.21.0",
		"@tailwindcss/vite": "^4.1.18",
		"@types/react": "^19.2.13",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.3",
		"shadcn": "^3.8.4",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "~5.9.3",
		"vite": "^7.2.4"
	},
	"dependencies": {
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"is-mobile": "^5.0.0",
		"lucide-react": "^0.563.0",
		"marked": "^17.0.1",
		"radix-ui": "^1.4.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router-dom": "^7.13.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.4.0"
	}
}
