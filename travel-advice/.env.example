# =============================================================
# Travel Advice Comparator — Omgevingsvariabelen
# Kopieer dit bestand naar .env en vul de waarden in
# =============================================================

# Database
# Lokale ontwikkeling (SQLite):
DATABASE_URL="file:./dev.db"

# Productie (PostgreSQL — bv. Neon of Supabase):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Vercel Postgres (automatisch ingevuld via dashboard):
# DATABASE_URL="postgres://..."
# POSTGRES_URL_NON_POOLING="postgres://..."  ← voor migraties

# Beveiliging cron-endpoint
# Genereer met: openssl rand -hex 32
CRON_SECRET="vervang-dit-door-een-willekeurige-string"

# Optioneel: expliciete Node-omgeving
# NODE_ENV="production"
